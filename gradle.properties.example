mpsHomeDir=<mps_home>
mpsqa.home=<current_directory>
github_username=<github user name to be able to access dependencies from github MAVEN packages>
github_token=<a token for the above use, the token shall have "read_packages" enabled>

# Performance tuning
org.gradle.parallel=true
org.gradle.jvmargs=-Xmx4g -XX:+UseG1GC -XX:+HeapDumpOnOutOfMemoryError
org.gradle.caching=true
org.gradle.daemon=true
